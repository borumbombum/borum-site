---
layout: base
---

{% import "macros/heros.njk" as hero with context %}

{{ hero.article(title, description, image, imageCaption) }}

<article class="article">
    {% if role %}
        <div class="wrapper project project-single">
            <dl class="project-meta mt-1">
                <dt>Rol</dt>
                <dd>{{ role }}</dd>

                <dt>Período</dt>
                <dd>{{ period }}</dd>

                <dt>Estado</dt>
                <dd>{{ status }}</dd>

                <dt>Pila</dt>
                <dd>{{ stack }}</dd>
            </dl>         
        </div> 

        {# Visit button #}
        {% if url %}
            <div class="wrapper ">
                {% set project_cta_text = "" %}
                {% set project_cta_url = url %}

                {% if url_button %}
                    {% set project_cta_text = url_button %}
                {% else %}
                    {% set project_cta_text = "Visitar" %}
                {% endif %}
                
                <a href="{{ project_cta_url }}" class="btn btn-sm btn-primary btn-cta fit-content mt-1" {% if url %} target="_blank" rel="noopener noreferrer" {% endif %}>{{ project_cta_text }}</a>
            </div>
        {% endif %}
        
    {% endif %}

    {% templatey content %}



    {# {{ content | safe  }} #}
</article>

<div class="tags wrapper mt-2">
    {% for tag in tags %}
        {% if tag != "posts" %}
            <a href="/tag/{{ tag | slugify }}/"><span class="pill">{{ tag }}</span></a>
        {% endif %}
    {% endfor %}
    <p class="mt-1"><a href="/">← Volver al archivo</a></p>
</div>

{% if videos %}
<div class="wrapper mt-2">
    <div class="video-grid" style="gap: 1rem;">
        {% for video in videos %}
            <iframe
                width="100%"
                height="200"
                src="https://www.youtube.com/embed/{{ video | replace('https://www.youtube.com/watch?v=', '') }}"
                title="YouTube video"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
            </iframe>
        {% endfor %}
    </div>
</div>
{% endif %}
