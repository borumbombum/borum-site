---
pagination:
    data: collections
    size: 1
    alias: tag
    addAllPagesToCollections: true
    layout: base
permalink: /tag/{{ tag | slugify }}/
eleventyComputed:
    title: Archivado en "{{ tag }}"
---
{% import "macros/lists.njk" as list %}
<div id="main" class="archive wrapper wrapper-wide mt-2">
    {{ list.archive_with_dates(collections[tag]) }}
</div>